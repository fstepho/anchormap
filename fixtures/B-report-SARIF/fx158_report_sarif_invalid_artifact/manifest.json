{
	"id": "fx158_report_sarif_invalid_artifact",
	"family": "B-report-SARIF",
	"purpose": "report rejects invalid SARIF input artifacts with code 4 and empty stdout.",
	"command": [
		"node",
		"dist/anchormap.js",
		"report",
		"--scan",
		"artifacts/invalid-scan.json",
		"--format",
		"sarif"
	],
	"cwd": ".",
	"exit_code": 4,
	"stdout": {
		"kind": "empty"
	},
	"stderr": {
		"kind": "ignored"
	},
	"filesystem": {
		"kind": "no_mutation"
	},
	"tags": ["report", "sarif", "artifact_io", "cli_boundary"],
	"groups": ["m20"]
}

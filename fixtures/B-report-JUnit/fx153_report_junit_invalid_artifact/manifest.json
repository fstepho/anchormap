{
	"id": "fx153_report_junit_invalid_artifact",
	"family": "B-report-JUnit",
	"purpose": "report rejects invalid check artifacts for JUnit with code 4 and empty stdout.",
	"command": [
		"node",
		"dist/anchormap.js",
		"report",
		"--check",
		"artifacts/invalid-check.json",
		"--format",
		"junit"
	],
	"cwd": ".",
	"exit_code": 4,
	"stdout": {
		"kind": "empty"
	},
	"stderr": {
		"kind": "ignored"
	},
	"filesystem": {
		"kind": "no_mutation"
	},
	"tags": ["report", "junit", "artifact_io", "invalid"],
	"groups": ["m20"]
}

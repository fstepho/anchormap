{
	"id": "fx60_map_replace_guard",
	"family": "B-map",
	"purpose": "map with an existing mapping and no --replace exits 4 before spec indexing and preserves anchormap.yaml.",
	"command": [
		"node",
		"dist/anchormap.js",
		"map",
		"--anchor",
		"FR-014",
		"--seed",
		"src/missing.ts"
	],
	"cwd": ".",
	"exit_code": 4,
	"stdout": {
		"kind": "ignored"
	},
	"stderr": {
		"kind": "ignored"
	},
	"filesystem": {
		"kind": "no_mutation"
	},
	"tags": ["map", "replace", "priority"],
	"groups": ["m8"]
}

{
	"id": "fx138_report_scan_diff_markdown",
	"family": "B-report",
	"purpose": "report renders stable Markdown from scan and diff artifacts without a policy section.",
	"command": [
		"node",
		"dist/anchormap.js",
		"report",
		"--scan",
		"artifacts/scan.json",
		"--diff",
		"artifacts/diff.json",
		"--format",
		"markdown"
	],
	"cwd": ".",
	"exit_code": 0,
	"stdout": {
		"kind": "golden"
	},
	"stderr": {
		"kind": "empty"
	},
	"filesystem": {
		"kind": "no_mutation"
	},
	"tags": ["report", "markdown", "golden", "artifact_io", "diff"],
	"groups": ["m19"]
}

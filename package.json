{
	"name": "anchormap",
	"private": true,
	"version": "0.0.0",
	"description": "Local deterministic structural traceability CLI for narrow-scope TypeScript repositories.",
	"bin": {
		"anchormap": "dist/anchormap.js"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/fstepho/anchormap.git"
	},
	"packageManager": "npm@11.11.1",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"check:docs": "sh scripts/check-docs-consistency.sh",
		"clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
		"build": "npm run clean && tsc -p tsconfig.json",
		"check:goldens": "npm run test:fixtures -- --goldens-only",
		"format": "biome format --write src package.json tsconfig.json biome.json",
		"lint": "biome check src package.json tsconfig.json biome.json",
		"lint:rules": "biome lint src package.json tsconfig.json biome.json",
		"test": "npm run test:unit",
		"test:docs": "npm run check:docs && npm run build && node --test \"dist/package-scripts.test.js\" \"dist/harness/docs-consistency.test.js\" \"dist/harness/lint-tasks-fixture.test.js\" \"dist/harness/workflow-preflight-fixture.test.js\"",
		"test:fixtures": "npm run build && node dist/harness/fixture-runner.js",
		"test:fixtures:all": "npm run test:fixtures",
		"test:harness": "npm run build && node --test \"dist/cli-stub.test.js\" \"dist/harness/fixture-*.test.js\" \"dist/harness/harness-smoke-fixtures.test.js\"",
		"test:product": "npm run build && node --test \"dist/bootstrap.test.js\" \"dist/cli/**/*.test.js\" \"dist/domain/**/*.test.js\" \"dist/infra/**/*.test.js\" \"dist/render/**/*.test.js\"",
		"test:unit": "npm run build && node --test \"dist/**/*.test.js\"",
		"workflow:preflight": "sh scripts/workflow-preflight.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/node": "25.6.0"
	},
	"dependencies": {
		"commonmark": "0.30.0",
		"typescript": "6.0.3",
		"yaml": "2.8.3"
	}
}

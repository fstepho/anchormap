{
	"name": "anchormap",
	"version": "1.2.0",
	"description": "Audit structural traceability between spec anchors and TypeScript code.",
	"license": "MIT",
	"private": false,
	"keywords": [
		"cli",
		"traceability",
		"typescript",
		"static-analysis",
		"requirements"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"bin": {
		"anchormap": "bin/anchormap"
	},
	"files": [
		"npm-shrinkwrap.json",
		"bin/anchormap",
		"dist/anchormap.js",
		"dist/cli/command-args.js",
		"dist/cli/commands.js",
		"dist/domain/anchor-id.js",
		"dist/domain/canonical-order.js",
		"dist/domain/finding.js",
		"dist/domain/repo-path.js",
		"dist/domain/scan-engine.js",
		"dist/domain/scan-result.js",
		"dist/infra/config-io.js",
		"dist/infra/config-yaml-render.js",
		"dist/infra/product-files.js",
		"dist/infra/repo-fs.js",
		"dist/infra/scaffold.js",
		"dist/infra/spec-index.js",
		"dist/infra/ts-graph.js",
		"dist/render/render-json.js"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fstepho/anchormap.git"
	},
	"homepage": "https://github.com/fstepho/anchormap#readme",
	"bugs": {
		"url": "https://github.com/fstepho/anchormap/issues"
	},
	"packageManager": "npm@11.11.1",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"check:docs": "sh scripts/check-docs-consistency.sh",
		"clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
		"build": "npm run clean && tsc -p tsconfig.json",
		"bench:release": "npm run build && node scripts/release-benchmark.mjs",
		"bench:validate": "node scripts/validate-release-benchmark-report.mjs bench/reports/gate-f-report.json",
		"bench:validate:artifacts": "node scripts/validate-release-benchmark-report.mjs --require-supported-platform-artifacts reports/t9.4",
		"audit:reproducibility": "node scripts/reproducibility-audit.mjs",
		"audit:reproducibility:update": "node scripts/reproducibility-audit.mjs --write",
		"release:gates": "node scripts/release-gate-aggregator.mjs",
		"release:publication-dry-run": "npm run build && node scripts/publication-dry-run.mjs",
		"verify:installed-artifact": "npm run build && node scripts/verify-installed-artifact.mjs",
		"check:goldens": "npm run test:fixtures -- --goldens-only",
		"format": "biome format --write src package.json tsconfig.json biome.json",
		"lint": "biome check src package.json tsconfig.json biome.json",
		"lint:rules": "biome lint src package.json tsconfig.json biome.json",
		"test": "npm run test:unit",
		"test:docs": "npm run check:docs && npm run build && node --test \"dist/package-scripts.test.js\" \"dist/harness/docs-consistency.test.js\" \"dist/harness/lint-tasks-fixture.test.js\" \"dist/harness/workflow-preflight-fixture.test.js\"",
		"test:fixtures": "npm run build && node dist/harness/fixture-runner.js",
		"test:fixtures:all": "npm run test:fixtures",
		"test:harness": "npm run build && node --test \"dist/cli-stub.test.js\" \"dist/harness/fixture-*.test.js\" \"dist/harness/harness-smoke-fixtures.test.js\"",
		"test:metamorphic": "npm run build && node --test \"dist/harness/metamorphic-fixtures.test.js\"",
		"test:product": "npm run build && node --test \"dist/bootstrap.test.js\" \"dist/cli/**/*.test.js\" \"dist/domain/**/*.test.js\" \"dist/infra/**/*.test.js\" \"dist/render/**/*.test.js\"",
		"test:unit": "npm run build && node --test \"dist/**/*.test.js\"",
		"workflow:preflight": "sh scripts/workflow-preflight.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/node": "25.6.0"
	},
	"dependencies": {
		"commonmark": "0.30.0",
		"typescript": "6.0.3",
		"yaml": "2.8.3"
	}
}
